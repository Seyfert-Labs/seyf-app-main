# Etherfuse FX API — sandbox (devnet)
# 1) Cuenta: https://devnet.etherfuse.com
# 2) API key: Ramp → API Keys → https://devnet.etherfuse.com/ramp/manage-api
# 3) Auth: header Authorization = la clave tal cual (sin prefijo Bearer)
# Docs: https://docs.etherfuse.com/initial-setup

ETHERFUSE_API_BASE_URL=https://api.sand.etherfuse.com
ETHERFUSE_API_KEY=

# La cookie httpOnly de /identidad (seyf_ef_onboarding) guarda customerId/bankAccountId de esa org.
# Si cambias ETHERFUSE_API_KEY u org, borra la cookie (Reiniciar prueba en /identidad) o la API fallará.

# Paso 2 — modelo Seyf ↔ Etherfuse (ver lib/etherfuse/integration-model.ts)
# hosted = URL firmada → UI Etherfuse (recomendado para iterar el MVP)
# programmatic = KYC en tu app vía API (más trabajo de producto)
ETHERFUSE_ONBOARDING_MODE=hosted

# Cadena de la wallet del cliente en rampa (MVP Seyf = stellar)
ETHERFUSE_DEFAULT_BLOCKCHAIN=stellar

# MVP Depositar: wallet + CLABE desde tu org Etherfuse (GET /ramp/wallets, /ramp/bank-accounts)
# Opcional si la API no puede inferir el cliente:
ETHERFUSE_MVP_CUSTOMER_ID=5f...
ETHERFUSE_MVP_STELLAR_PUBLIC_KEY=hgguig
# UUID de GET /ramp/bank-accounts (cuenta activa, sin deletedAt). Si está borrada en Etherfuse, la app usa otra activa.
ETHERFUSE_MVP_BANK_ACCOUNT_ID=1234567890
# UUID de GET /ramp/wallets (Stellar: evita "Proxy account not found" en POST /ramp/order)
# ETHERFUSE_MVP_CRYPTO_WALLET_ID=

# Paso 4 — cotización / orden onramp (rutas /api/seyf/etherfuse/*) y webhooks
# En producción: SEYF_ALLOW_ETHERFUSE_RAMP=true o las rutas devuelven 403
SEYF_ALLOW_ETHERFUSE_RAMP=true
# Opcional: activo destino si GET /ramp/assets viene vacío o quieres forzar un identifier YA listado ahí.
# Debe coincidir con `identifier` de /ramp/assets; issuers distintos por entorno → si no, error NonStableAsset.
# ETHERFUSE_ONRAMP_TARGET_ASSET=
# Offramp (crypto → MXN): activo fuente si quieres forzar; debe estar en GET /ramp/assets para esa wallet.
# ETHERFUSE_OFFRAMP_SOURCE_ASSET=
# Secreto del webhook (base64, solo se muestra al crear el webhook en Etherfuse)
ETHERFUSE_WEBHOOK_SECRET=
# URL de ejemplo para registrar en devnet: https://TU-DOMINIO/api/webhooks/etherfuse
# Simular SPEI en sandbox tras crear orden: https://docs.etherfuse.com/sandbox-api/fiat-received

# Paneles /dev/etherfuse-ramp, /dev/etherfuse-offramp, /dev/poc-omnibus y POST sandbox fiat_received. En development ya está activo.
# SEYF_ETHERFUSE_DEV_PANEL=true

# En prod/preview: muestra «Reiniciar prueba» en /identidad (borra cookie local). En NODE_ENV=development ya está activo.
SEYF_ALLOW_KYC_RESET=true
