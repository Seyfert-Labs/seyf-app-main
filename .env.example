# Etherfuse FX API — sandbox (devnet)
# 1) Cuenta: https://devnet.etherfuse.com
# 2) API key: Ramp → API Keys → https://devnet.etherfuse.com/ramp/manage-api
# 3) Auth: header Authorization = la clave tal cual (sin prefijo Bearer)
# Docs: https://docs.etherfuse.com/initial-setup

ETHERFUSE_API_BASE_URL=https://api.sand.etherfuse.com
ETHERFUSE_API_KEY=

# La cookie httpOnly de /identidad (seyf_ef_onboarding) guarda customerId/bankAccountId de esa org.
# Si cambias ETHERFUSE_API_KEY u org, borra la cookie (Reiniciar prueba en /identidad) o la API fallará.

# Paso 2 — modelo Seyf ↔ Etherfuse (ver lib/etherfuse/integration-model.ts)
# hosted = URL firmada → UI Etherfuse (recomendado para iterar el MVP)
# programmatic = KYC en tu app vía API (más trabajo de producto)
ETHERFUSE_ONBOARDING_MODE=hosted

# Cadena de la wallet del cliente en rampa (MVP Seyf = stellar)
ETHERFUSE_DEFAULT_BLOCKCHAIN=stellar

# MVP Depositar: wallet + CLABE desde tu org Etherfuse (GET /ramp/wallets, /ramp/bank-accounts)
# --- MVP dev-only fallback (NO usar en producción) ---
# En producción la cookie seyf_ef_onboarding (creada en /identidad) es la fuente de verdad.
# El flujo de producción: Pollar crea wallet → /identidad registra esa wallet en Etherfuse → cookie.
# Estas vars solo sirven para probar sin completar el onboarding:
# ETHERFUSE_MVP_CUSTOMER_ID=<UUID de GET /ramp/customers>
# ETHERFUSE_MVP_STELLAR_PUBLIC_KEY=<G... clave Stellar de GET /ramp/wallets>
# ETHERFUSE_MVP_BANK_ACCOUNT_ID=<UUID de GET /ramp/bank-accounts (cuenta activa, sin deletedAt)>
# ETHERFUSE_MVP_CRYPTO_WALLET_ID=<UUID de GET /ramp/wallets (evita "Proxy account not found")>

# Paso 4 — cotización / orden onramp (rutas /api/seyf/etherfuse/*) y webhooks
# En producción: SEYF_ALLOW_ETHERFUSE_RAMP=true o las rutas devuelven 403
SEYF_ALLOW_ETHERFUSE_RAMP=true
# Opcional: activo destino si GET /ramp/assets viene vacío o quieres forzar un identifier YA listado ahí.
# Debe coincidir con `identifier` de /ramp/assets; issuers distintos por entorno → si no, error NonStableAsset.
# ETHERFUSE_ONRAMP_TARGET_ASSET=
# Offramp (crypto → MXN): activo fuente si quieres forzar; debe estar en GET /ramp/assets para esa wallet.
# ETHERFUSE_OFFRAMP_SOURCE_ASSET=
# Secreto del webhook (base64, solo se muestra al crear el webhook en Etherfuse)
ETHERFUSE_WEBHOOK_SECRET=
# Importante: registrar evento kyc_updated apuntando a /api/webhooks/etherfuse
# URL de ejemplo para registrar en devnet: https://TU-DOMINIO/api/webhooks/etherfuse
# Simular SPEI en sandbox tras crear orden: https://docs.etherfuse.com/sandbox-api/fiat-received

# Paneles /dev/etherfuse-ramp, /dev/etherfuse-offramp, /dev/poc-omnibus y POST sandbox fiat_received. En development ya está activo.
# SEYF_ETHERFUSE_DEV_PANEL=true
# Token opcional para proteger endpoints de backoffice Etherfuse en producción (/api/seyf/etherfuse/ops/*).
# SEYF_ETHERFUSE_OPS_TOKEN=

# Nombre mostrado en el recuento SPEI del panel dev (default: Etherfuse).
# SEYF_SPEI_DISPLAY_NAME=Etherfuse

# En prod/preview: muestra «Reiniciar prueba» en /identidad (borra cookie local). En NODE_ENV=development ya está activo.
SEYF_ALLOW_KYC_RESET=true

# --- Notificaciones SMS (M09)
# En dev, si faltan estas credenciales el proveedor cae en modo mock y solo deja rastro en notification_log.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Usa uno de los dos siguientes:
TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=
# Protege POST /api/seyf/internal/notify cuando el hook se use fuera del proceso principal.
SEYF_INTERNAL_NOTIFY_SECRET=

# --- Pollar (wallet embebida Stellar) — https://docs.pollar.xyz/docs/getting-started/api-keys
# Clave publicable desde https://dashboard.pollar.xyz/ (testnet / mainnet según tu app).
NEXT_PUBLIC_POLLAR_API_KEY=
# En Dashboard → Domains / allowed origins: incluye la URL exacta del navegador (localhost y 127.0.0.1 son distintos).
# Alias aceptado por el código (misma clave que arriba si solo usas una variable):
# NEXT_PUBLIC_POLLAR_PUBLISHABLE_KEY=
# Red Stellar para el SDK y Horizon (fallback: NEXT_PUBLIC_ACCESLY_NETWORK, NEXT_PUBLIC_STELLAR_NETWORK).
NEXT_PUBLIC_POLLAR_STELLAR_NETWORK=testnet

# Testnet / sandbox Etherfuse: alta de cuenta bancaria automática al enviar KYC (sin pedir CLABE al usuario).
# Valor de 18 dígitos solo en servidor; debe ser aceptado por el sandbox de tu org (probar en panel Etherfuse si rechaza).
# Desactivar explícitamente: SEYF_TESTNET_AUTOFILL_BANK_ACCOUNT=false
# SEYF_TESTNET_SYNTHETIC_CLABE=
